# TRUSTED PROXIES
# Để trống (hoặc không khai báo) = Không tin tưởng proxy nào, lấy IP trực tiếp (an toàn nhất)
# Nếu dùng Nginx làm reverse proxy, điền: 127.0.0.1
# Nếu có nhiều proxy, cách nhau bằng dấu phẩy: 127.0.0.1,192.168.1.100
TRUSTED_PROXIES=
# Cổng của ứng dụng
PORT=5000